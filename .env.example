# Supabase — required to enable accounts, organizations and agent entitlements.
# Find these in your Supabase project: Settings -> API.
# When unset, the app runs in public demo mode (auth disabled).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: passcode for the investor-relations gate (defaults to "demo").
NEXT_PUBLIC_PASSCODE=demo
