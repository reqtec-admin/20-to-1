# Demo mode (default: true). Set to false to enable live Stripe checkout.
# Use NEXT_PUBLIC_DEMO for client-side UI; DEMO is also read on the server.
NEXT_PUBLIC_DEMO=true
DEMO=true

# Stripe (required when DEMO=false / NEXT_PUBLIC_DEMO=false)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: canonical site URL for Stripe redirect URLs (falls back to request origin)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Investor passcode gate (default: demo)
NEXT_PUBLIC_PASSCODE=demo
